# =============================================================
#  Obsidian Research Assistant — Environment Configuration
#  Copy to .env for local dev. Set these in Render's dashboard
#  for production (never commit the real .env file).
# =============================================================

# ── Server ──────────────────────────────────────────────────
# Render injects PORT automatically. 3001 is used locally.
PORT=3001
NODE_ENV=development         # set to "production" on Render

# ── CORS ────────────────────────────────────────────────────
# Leave blank in production — frontend and API are same-origin on Render.
# Set to your Vercel URL if you deploy the frontend to Vercel separately:
# CORS_ORIGIN=https://my-app.vercel.app
CORS_ORIGIN=*

# ── Spring Boot proxy ────────────────────────────────────────
# The URL of your Spring Boot authentication backend.
# server.js proxies /api/spring/* → SPRING_BASE_URL/api/*
SPRING_BASE_URL=https://obsidian-backend-n8zo.onrender.com

# ── Ollama LLM ──────────────────────────────────────────────
# Local dev: Ollama running on your machine.
# Production (Render): Ollama is NOT available on the free tier.
#   Option A — Leave as-is; AI chat features will fail gracefully.
#   Option B — Point to a self-hosted Ollama instance (GPU server, Fly.io, etc.).
#   Option C — Replace llm.js with OpenAI / Groq / Anthropic API calls.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=60000

# ── SQLite database ─────────────────────────────────────────
# Local dev: stored in chatbot-server/db/
# Render free tier: use /tmp/ — WARNING: data is wiped on each redeploy.
# For persistence: add a Render Disk (paid) or migrate to Turso/PlanetScale.
DB_PATH=./db/obsidian.db

# ── Chat settings ────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_MS=1000
MAX_CONTEXT_MESSAGES=10
MAX_MESSAGE_LENGTH=4000
SESSION_TTL_HOURS=24

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
